{
  "title": "Galaxy Vast â€” Operations",
  "uid": "galaxyvast-ops",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Kill Switch Status",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [{"expr": "galaxyvast_kill_switch_active", "legendFormat": "Kill Switch"}]
    },
    {
      "id": 2,
      "title": "License Failures (5m)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [{"expr": "increase(galaxyvast_license_failures_total[5m])", "legendFormat": "Failures"}]
    },
    {
      "id": 3,
      "title": "Heartbeat Losses (10m)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [{"expr": "increase(galaxyvast_heartbeat_losses_total[10m])", "legendFormat": "Losses"}]
    },
    {
      "id": 4,
      "title": "Equity Drawdown %",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [{"expr": "galaxyvast_equity_drawdown_pct", "legendFormat": "Drawdown"}]
    },
    {
      "id": 5,
      "title": "Reconciliation Mismatches (15m)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [{"expr": "increase(galaxyvast_reconciliation_mismatches_total[15m])", "legendFormat": "Mismatches"}]
    },
    {
      "id": 6,
      "title": "APB’equest Rate",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "rate(http_requests_total[5m])", "legendFormat": "{{method}} {{path}}"}]
    },
    {
      "id": 7,
      "title": "API Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "rate(http_requests_total{status=~"5.."}[5m])", "legendFormat": "5xx"}]
    },
    {
      "id": 8,
      "title": "Active Subscriptions",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 10},
      "targets": [{"expr": "galaxyvast_subscriptions_active", "legendFormat": "Active"}]
    },
    {
      "id": 9,
      "title": "Trade Latency (p95)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 6, "y": 10},
      "targets": [{"expr": "histogram_quantile(0.95, galaxyvast_trade_latency_seconds_bucket)", "legendFormat": "p95"}]
    },
    {
      "id": 10,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 16},
      "targets": [{"expr": "container_memory_usage_bytes{name=~'galaxyvast.*'}", "legendFormat": "{{name}}"}]
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser"
}
