{
  "title": "MT5Trading SaaS Admin Observability",
  "uid": "mt5trading-phase15",
  "tags": ["mt5trading", "saas", "admin"],
  "refresh": "30s",
  "time": {"from": "now-3h", "to": "now"},
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Kill Switch Active",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "kill_switch_active", "legendFormat": "Active"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [
        {"value": 0, "color": "green"}, {"value": 1, "color": "red"}
      ]}, "mappings": [{"type": "value", "options": {"0": {"text": "OFF"}, "1": {"text": "ON"}}}]}}
    },
    {
      "id": 2, "type": "stat", "title": "License Failures (5m)",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "increase(license_failures_total_total[5m])"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [
        {"value": 0, "color": "green"}, {"value": 3, "color": "yellow"}, {"value": 10, "color": "red"}
      ]}}}
    },
    {
      "id": 3, "type": "stat", "title": "Heartbeat Losses (5m)",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "increase(heartbeat_losses_total_total[5m])"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [
        {"value": 0, "color": "green"}, {"value": 1, "color": "orange"}, {"value": 5, "color": "red"}
      ]}}}
    },
    {
      "id": 4, "type": "gauge", "title": "Equity Drawdown %",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "equity_drawdown_pct"}],
      "fieldConfig": {"defaults": {
        "min": 0, "max": 20, "unit": "percent",
        "thresholds": {"steps": [
          {"value": 0, "color": "green"}, {"value": 5, "color": "yellow"}, {"value": 10, "color": "red"}
        ]}
      }}
    },
    {
      "id": 5, "type": "stat", "title": "Reconciliation Mismatches",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "reconciliation_mismatches_total_total"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [
        {"value": 0, "color": "green"}, {"value": 1, "color": "red"}
      ]}}}
    },
    {
      "id": 6, "type": "stat", "title": "API Status",
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "up{job='mt5trading-api'}"}],
      "fieldConfig": {"defaults": {"mappings": [
        {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
      ]}}
    },
    {
      "id": 10, "type": "timeseries", "title": "License Failures Over Time",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"expr": "increase(license_failures_total_total[5m])", "legendFormat": "Failures/5m"},
        {"expr": "increase(license_validations_total_total[5m])", "legendFormat": "Success/5m"}
      ]
    },
    {
      "id": 11, "type": "timeseries", "title": "Heartbeat Status",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"expr": "increase(heartbeat_received_total_total[5m])", "legendFormat": "Received/5m"},
        {"expr": "increase(heartbeat_losses_total_total[5m])", "legendFormat": "Lost/5m"}
      ]
    },
    {
      "id": 20, "type": "timeseries", "title": "Trade Activity",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "targets": [
        {"expr": "rate(trades_submitted_total_total[5m])", "legendFormat": "Submitted/s"},
        {"expr": "rate(trades_rejected_total_total[5m])", "legendFormat": "Rejected/s"}
      ]
    }
  ]
}
