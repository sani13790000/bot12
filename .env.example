# Bot12 MCP Server - Environment Variables Template
# Copy this to .env and fill in your actual values
# IMPORTANT: Add .env to .gitignore - never commit real credentials!

# ============================================================================
# METATRADER 5 CREDENTIALS
# ============================================================================
# Get these from your MT5 account settings
MT5_LOGIN=your_mt5_account_number
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_mt5_broker_server
MT5_PATH=/path/to/terminal64.exe

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_api_key
SUPABASE_DB_PASSWORD=your_supabase_db_password

# ============================================================================
# API CREDENTIALS (If using external data providers)
# ============================================================================
# Example: Financial data API, alternative broker APIs, etc.
API_KEY_FINANCIAL_DATA=your_api_key
API_SECRET_BROKER=your_broker_secret

# ============================================================================
# MCP SERVER CONFIGURATION
# ============================================================================
# Port for HTTP transport (if using HTTP instead of stdio)
MCP_PORT=3000
MCP_HOST=localhost

# Authentication token for MCP access (optional, for security)
MCP_AUTH_TOKEN=your_auth_token_here

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=bot12_mcp.log
LOG_FORMAT=json

# ============================================================================
# TRADING CONFIGURATION
# ============================================================================
# Rate limiting: max trades per minute
MAX_TRADES_PER_MINUTE=10

# Default lot size for trades (if not specified)
DEFAULT_LOT_SIZE=0.1

# Paper trading mode (set to true to avoid real trading)
PAPER_TRADING_MODE=false

# Risk management: max daily loss percentage
MAX_DAILY_LOSS_PERCENT=2.0

# Risk management: max drawdown percentage
MAX_DRAWDOWN_PERCENT=5.0

# ============================================================================
# DATABASE BACKUP & LOGGING
# ============================================================================
# Where to store trade logs
TRADE_LOG_PATH=./logs/trades
BACKUP_PATH=./backups

# ============================================================================
# DEVELOPMENT / DEBUG
# ============================================================================
# Set to true for verbose debugging
DEBUG_MODE=false

# Set to true to print all API calls
DEBUG_API_CALLS=false

# Enable test mode (uses mock data)
TEST_MODE=false
