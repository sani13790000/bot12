# ============================================================
# Galaxy Vast AI Trading Platform — Environment Variables
# ============================================================

# --- Environment ---
ENVIRONMENT=development
LOG_LEVEL=INFO
JSON_LOGS=true

# --- Supabase / PostgreSQL ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security (generate with: python -c "import secrets; print(secrets.token_hex(32))") ---
JWT_SECRET_KEY=replace-with-64-char-hex-secret
API_SECRET_KEY=replace-with-64-char-hex-secret
LICENSE_SECRET_KEY=replace-with-64-char-hex-secret
LICENSE_SALT=replace-with-64-char-hex-salt

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8501

# --- Sentry (optional) ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Telegram ---
TELEGRAM_BOT_TOKEN=1234567890:ABCdef...
TELEGRAM_ADMIN_IDS=123456789

# --- MetaTrader 5 ---
MT5_EXE_PATH=C:\\Program Files\\MetaTrader 5\\terminal64.exe
MT5_LOGIN=12345678
MT5_PASSWORD=your_password
MT5_SERVER=YourBroker-Server

# --- Trading defaults ---
DEFAULT_SYMBOL=XAUUSD
DEFAULT_TIMEFRAME=M15
DEFAULT_RISK_PERCENT=1.0
MAX_DAILY_TRADES=5

# --- Dashboard ---
STREAMLIT_SERVER_PORT=8501
API_BASE_URL=http://localhost:8000
