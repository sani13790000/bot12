# =============================================================
# Galaxy Vast AI Trading Platform — Environment Variables
# =============================================================
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# All fields marked REQUIRED must be set before starting.
# =============================================================

# ----------------------------------------------------------
# App
# ----------------------------------------------------------
ENVIRONMENT=production          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# ----------------------------------------------------------
# Supabase (REQUIRED)
# ----------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key      # service_role key, NOT anon key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret     # min 32 chars

# ----------------------------------------------------------
# JWT (REQUIRED) — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------
JWT_SECRET_KEY=generate-a-64-char-hex-secret-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20

# ----------------------------------------------------------
# CORS — comma-separated list of allowed origins
# ----------------------------------------------------------
ALLOWED_ORIGINS=https://yourdomain.com,https://dashboard.yourdomain.com

# ----------------------------------------------------------
# Telegram (REQUIRED for bot)
# ----------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456789:ABC-your-bot-token
TELEGRAM_ADMIN_IDS=123456789,987654321           # comma-separated Telegram user IDs
TELEGRAM_WEBHOOK_SECRET=generate-random-secret

# ----------------------------------------------------------
# Licensing (REQUIRED)
# ----------------------------------------------------------
LICENSE_SECRET=generate-a-32-char-secret-here
LICENSE_SALT=generate-another-32-char-secret-here

# ----------------------------------------------------------
# MQL5 EA — token for MetaTrader EA → API authentication
# ----------------------------------------------------------
MQL5_API_TOKEN=generate-a-secure-token-here

# ----------------------------------------------------------
# Observability (optional)
# ----------------------------------------------------------
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
ENABLE_METRICS=true
API_BASE_URL=http://api:8000

# ----------------------------------------------------------
# Backtest
# ----------------------------------------------------------
BACKTEST_MAX_WORKERS=4
BACKTEST_JOB_TIMEOUT=300
