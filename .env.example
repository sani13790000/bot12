# Bot12 - Enterprise MT5 Trading Bot - Environment Variables Template
# Copy this to .env and fill in your actual values
# CRITICAL SECURITY: Add .env to .gitignore - NEVER commit real credentials to GitHub!

# ============================================================================
# SECURITY & JWT (CRITICAL - MUST BE SET IN PRODUCTION)
# ============================================================================
# JWT secret for token signing (MUST be cryptographically secure)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secure-jwt-secret-key-min-32-chars
ENVIRONMENT=development

# ============================================================================
# METATRADER 5 CREDENTIALS & GATEWAY
# ============================================================================
# Get these from your MT5 account settings
MT5_LOGIN=your_mt5_account_number
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_mt5_broker_server
MT5_GATEWAY_URL=http://localhost:8080
MT5_DEMO_MODE=true
GATEWAY_API_KEY=your_gateway_api_key

# ============================================================================
# SUPABASE DATABASE CONFIGURATION
# ============================================================================
# Get from your Supabase project settings
DATABASE_URL=postgresql://user:password@localhost:5432/bot12
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_api_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# ============================================================================
# LICENSE MANAGEMENT (CRITICAL)
# ============================================================================
LICENSE_SECRET=your-license-secret-key
LICENSE_SALT=your-license-salt
MQL5_API_TOKEN=your_mql5_api_token

# ============================================================================
# ENCRYPTION & SECURITY (CRITICAL)
# ============================================================================
# Master key for field-level encryption
SECRETS_MASTER_KEY=your-master-encryption-key
FIELD_ENCRYPTION_KEY=your-field-encryption-key

# ============================================================================
# EXTERNAL API CREDENTIALS (If using external data providers)
# ============================================================================
# Financial data API, payment gateways, etc.
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
ZARINPAL_WEBHOOK_SECRET=your_zarinpal_webhook_secret
API_KEY_FINANCIAL_DATA=your_api_key
API_SECRET_BROKER=your_broker_secret

# ============================================================================
# TELEGRAM BOT CONFIGURATION
# ============================================================================
# Get from BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_ADMIN_IDS=123456789,987654321
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# ============================================================================
# API SERVER CONFIGURATION
# ============================================================================
API_PREFIX=/api/v1
API_BASE_URL=http://localhost:8000
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
TRUSTED_HOSTS=localhost,127.0.0.1

# Rate limiting
RATE_LIMIT_API_PER_MINUTE=60

# ============================================================================
# ADMIN & SECURITY
# ============================================================================
ADMIN_IP_ALLOWLIST=127.0.0.1,::1
BCRYPT_ROUNDS=12

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=logs/bot12.log
LOG_FORMAT=json
LOG_REDACTION_ENABLED=true

# Metrics & Monitoring
ENABLE_METRICS=true

# ============================================================================
# TRADING CONFIGURATION & RISK MANAGEMENT
# ============================================================================
# Paper trading mode (set to true to avoid real trading)
PAPER_TRADING_MODE=false

# Maximum daily loss as percentage of equity
MAX_DAILY_LOSS_PCT=5.0

# Maximum position size as percentage of equity
MAX_POSITION_SIZE_PCT=2.0

# Maximum concurrent open trades
MAX_OPEN_TRADES=5

# Default risk per trade as percentage
DEFAULT_RISK_PER_TRADE_PCT=1.0

# SMC Engine Configuration
SMC_MAX_CANDLES=1000

# Analytics
ANALYTICS_PAGE_SIZE=100

# ============================================================================
# BACKTEST & MODEL TRAINING
# ============================================================================
# Max parallel workers for backtesting
BACKTEST_MAX_WORKERS=4

# Backtest job timeout in seconds
BACKTEST_JOB_TIMEOUT=300

# Model storage directory
MODEL_DIR=/data/models

# Minimum trades for Sharpe ratio calculation
METRICS_MIN_TRADES_FOR_SHARPE=30

# Security model retraining interval (seconds)
SECURITY_MODEL_RETRAIN_INTERVAL_S=3600

# ============================================================================
# PATHS & STORAGE
# ============================================================================
# Where to store trade logs
TRADE_LOG_PATH=./logs/trades
BACKUP_PATH=./backups

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=10

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Kill switch (immediate stop if activated)
KILL_SWITCH_ENABLED=true

# Self-learning and model adaptation
SELF_LEARNING_ENABLED=true

# Test mode (uses mock data, no real trades)
TEST_MODE=false

# ============================================================================
# DEVELOPMENT / DEBUG (Set to false in production!)
# ============================================================================
DEBUG_MODE=false
DEBUG_API_CALLS=false

# ============================================================================
# SESSION & COOKIES (Security)
# ============================================================================
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=strict
SESSION_COOKIE_HTTPONLY=true

# Content Security Policy
CSP_ENABLED=true
CSP_REPORT_ONLY=false
CSP_REPORT_URI=/api/v1/csp-report
