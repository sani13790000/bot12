# ========================================================================
# Galaxy Vast AI Trading Platform — .env.example (Phase 11)
# ========================================================================
# Copy:  cp .env.example .env
# Fill:  hame maqadeer REQUIRED ra par konid
# NEVER: hergaz .env ra be git commit nakonid
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"
# ========================================================================

# ----------------------------------------------------------------------
# App
# ----------------------------------------------------------------------
ENVIRONMENT=production                  # development | staging | production
DEBUG=false
LOG_LEVEL=INFO
LOG_REDACTION_ENABLED=true              # P11: hamishe true dar production

# ----------------------------------------------------------------------
# Master Secret Key (REQUIRED — P11-CFG-1)
# hadaqal 32 karaktar — braye ramznegari hame secrets dakheli
# ----------------------------------------------------------------------
SECRETS_MASTER_KEY=CHANGE_ME_generate_64_hex_chars_here_min_32_chars_required

# ----------------------------------------------------------------------
# Supabase (REQUIRED)
# ----------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key   # faqat backend
SUPABASE_JWT_SECRET=your-supabase-jwt-secret          # hadaqal 32 karaktar

# ----------------------------------------------------------------------
# JWT (REQUIRED)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME_min_32_chars_hex_generated
JWT_ALGORITHMCM52 0
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
BCRYPT_ROUNDS=12

# ----------------------------------------------------------------------
# Field-level DB Encryption (REQUIRED braye license/credentials)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# bayad daqiqan 64 karaktar hex (32 bytes) bashad
# ----------------------------------------------------------------------
FIELD_ENCRYPTION_KEY=CHANGE_ME_exactly_64_hex_chars_for_aes256_field_encryption

# ----------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/galaxyvast
REDIS_URL=redis://redis:379/0
REDIS_MAX_CONNECTIONS=20

# ----------------------------------------------------------------------
# CORS (P11-CFG-2,3)
# comma-separated — bedon trailing slash — bedon wildcard dar production
# ----------------------------------------------------------------------
ALLOWED_ORIGINS=https://yourdomain.com,https://dashboard.yourdomain.com

# ----------------------------------------------------------------------
# Cookie Security (P11-CFG-7)
# ----------------------------------------------------------------------
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=strict
SESSION_COOKIE_HTTPONLY=true

# ----------------------------------------------------------------------
# Content Security Policy (P11-CFG-4)
# ----------------------------------------------------------------------
CSP_ENABLED=true
CSP_REPORT_ONLY=false                   # true dar staging braye testing
CSP_REPORT_URI=/api/v1/csp-report

# ----------------------------------------------------------------------
# MT5 Broker (REQUIRED braye live trading)
# ----------------------------------------------------------------------
MT1_LOGIN=12345678
MT5_PASSWORD=CHANGE_ME_broker_password
MT5_SERVER=BrokerName-Live

# ----------------------------------------------------------------------
# Telegram (REQUIRED braye alerts)
# ----------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=CHAKGE_ME_bot_token
TELEGRAM_ADMIN_IDS=123456789
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_min_32_chars_random

# ----------------------------------------------------------------------
# Licensing (REQUIRED — P6)
# ----------------------------------------------------------------------
LICENSE_SECRET=CHANGE_ME_min_32_chars_random_hex
LICENSE_SALT=CHANGE_ME_different_32_chars_random_hex

# ----------------------------------------------------------------------
# MQL5 EA Authentication
# ----------------------------------------------------------------------
MQL6_API_TOKEN=CHANGE_ME_min_32_chars_random_token

# ----------------------------------------------------------------------
# Payment Webhooks (P10)
# ----------------------------------------------------------------------
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
ZARINPAL_WEBHOOK_SECRET CHANGE_ME_zarinpal_secret

# ----------------------------------------------------------------------
# Risk Management
# ----------------------------------------------------------------------
MAX_RISK_PCT=1.0
MAX_DAILY_DRAWDOWN_PCT=5.0
INITIAL_ACCOUNT_BALANCE=10000.0
MAX_OPEN_TRADES=5

# ----------------------------------------------------------------------
# Observability (optional)
# ----------------------------------------------------------------------
# SENTRY_DSN=https://your-key@sentry.io/project-id
ENABLE_METRIBS=true
API_BASE_URL=https://api.yourdomain.com

# ----------------------------------------------------------------------
# Backtest
# ----------------------------------------------------------------------
BACKTEST_MAX_WORKERS=4
BACKTEST_JOB_TIMEOUT=300

# ----------------------------------------------------------------------
# ⚠️  SECURITY CHECKLIST BEFORE DEPLOY
# ----------------------------------------------------------------------
# [ ] SECRETS_MASTER_KEY — generated, not default
# [ ] JWT_SECRET_KEY — generated, min 32 chars
# [ ] FIELD_ENCRYPTION_KEY ┠ generated, exactly 64 hex chars
# [ ] DATABASE_URL ┠ not localhost
# [ ] ALLOWED_ORIGINS — explicit domains, no wildcard
# [ ] MT5_PASSWORD ┠ not default/empty
# [ ] TELEGRAM_BOT_TOKEN — real token
# [ ] LICENSE_SECRET + LICENSE_SALT — both set
# [ ] DEBUG=false
# [ ] LOG_REDACTER_ENABLED=true
# [ ] SESSION_COOKIE_SECURE=true
# [ ] .env dar .gitignore ast
# [ ] .env.example dar git ast (bedone maqadeer vaqei) 