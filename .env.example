# ============================================================
# Galaxy Vast AI Trading Platform v2.0 — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ==================== REQUIRED ====================

# Supabase (get from https://supabase.com -> Settings -> API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxx.supabase.co:5432/postgres

# JWT (generate: python3 -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# License keys (generate same way as JWT_SECRET_KEY)
LICENSE_ENCRYPTION_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
LICENSE_SIGNATURE_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# ==================== TELEGRAM ====================

# Get from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
# Get from @userinfobot
TELEGRAM_ADMIN_IDS=123456789

# ==================== MT5 (Windows only) ====================

MT5_EXE_PATH=C:\\Program Files\\MetaTrader 5\\terminal64.exe
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Server

# ==================== OPTIONAL ====================

# Sentry (error tracking, get from https://sentry.io)
SENTRY_DSN=

# Redis (auto-set in docker-compose)
REDIS_URL=redis://redis:6379/0

# Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# Trading settings
DEFAULT_SYMBOL=XAUUSD
DEFAULT_RISK_PERCENT=1.0
TRADING_MODE=FULL_AUTO

# API
API_HOST=0.0.0.0
API_PORT=8000
