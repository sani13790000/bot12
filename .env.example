# ========================================================================
# Galaxy Vast AI Trading Platform — .env.example
# ========================================================================
# Copy:  cp .env.example .env
# Fill:  همه مقادیر REQUIRED را پر کنید
# NEVER: هرگز .env را به git commit نکنید
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"
# ========================================================================

# ----------------------------------------------------------------------
# App
# ----------------------------------------------------------------------
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_REDACTION_ENABLED=true

# ----------------------------------------------------------------------
# Master Secret Key (REQUIRED)
# ----------------------------------------------------------------------
SECRETS_MASTER_KEY=CHANGE_ME_generate_64_hex_chars_here_min_32_chars_required

# ----------------------------------------------------------------------
# Supabase (REQUIRED)
# ----------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ----------------------------------------------------------------------
# JWT (REQUIRED)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME_min_32_chars_hex_generated
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
BCRYPT_ROUNDS=12

# ----------------------------------------------------------------------
# Field-level DB Encryption (REQUIRED)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------------------
FIELD_ENCRYPTION_KEY=CHANGE_ME_exactly_64_hex_chars_for_aes256_field_encryption

# ----------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/galaxyvast
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_MAX_CONNECTIONS=20

# ----------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------
ALLOWED_ORIGINS=https://yourdomain.com,https://dashboard.yourdomain.com

# ----------------------------------------------------------------------
# Cookie Security
# ----------------------------------------------------------------------
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=strict
SESSION_COOKIE_HTTPONLY=true

# ----------------------------------------------------------------------
# Content Security Policy
# ----------------------------------------------------------------------
CSP_ENABLED=true
CSP_REPORT_ONLY=false
CSP_REPORT_URI=/api/v1/csp-report

# ----------------------------------------------------------------------
# MT5 Broker (REQUIRED)
# ----------------------------------------------------------------------
MT5_LOGIN=12345678
MT5_PASSWORD=CHANGE_ME_broker_password
MT5_SERVER=BrokerName-Live
MT5_DEMO_MODE=false

# ----------------------------------------------------------------------
# MT5 Gateway
# ----------------------------------------------------------------------
MT5_GATEWAY_URL=http://127.0.0.1:8080
MT5_GATEWAY_API_KEY=CHANGE_ME_min_32_chars_random_hex
GATEWAY_API_KEY=CHANGE_ME_min_32_chars_random_hex

# ----------------------------------------------------------------------
# Telegram (REQUIRED)
# ----------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=CHANGE_ME_bot_token
TELEGRAM_ADMIN_IDS=123456789
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_min_32_chars_random

# ----------------------------------------------------------------------
# Licensing (REQUIRED)
# ----------------------------------------------------------------------
LICENSE_SECRET=CHANGE_ME_min_32_chars_random_hex
LICENSE_SALT=CHANGE_ME_different_32_chars_random_hex

# ----------------------------------------------------------------------
# MQL5 EA Authentication
# ----------------------------------------------------------------------
MQL5_API_TOKEN=CHANGE_ME_min_32_chars_random_token

# ----------------------------------------------------------------------
# Admin Security
# ----------------------------------------------------------------------
ADMIN_IP_ALLOWLIST=127.0.0.1,::1

# ----------------------------------------------------------------------
# Payment Webhooks
# ----------------------------------------------------------------------
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
ZARINPAL_WEBHOOK_SECRET=CHANGE_ME_zarinpal_secret

# ----------------------------------------------------------------------
# Risk Management
# ----------------------------------------------------------------------
MAX_RISK_PCT=1.0
MAX_DAILY_DRAWDOWN_PCT=5.0
INITIAL_ACCOUNT_BALANCE=10000.0
MAX_OPEN_TRADES=5

# ----------------------------------------------------------------------
# Observability (optional)
# ----------------------------------------------------------------------
# SENTRY_DSN=https://your-key@sentry.io/project-id
ENABLE_METRICS=true
API_BASE_URL=https://api.yourdomain.com

# ----------------------------------------------------------------------
# Backtest
# ----------------------------------------------------------------------
BACKTEST_MAX_WORKERS=4
BACKTEST_JOB_TIMEOUT=300

# ----------------------------------------------------------------------
# SECURITY CHECKLIST BEFORE DEPLOY
# ----------------------------------------------------------------------
# [ ] SECRETS_MASTER_KEY — generated, not default
# [ ] JWT_SECRET_KEY — generated, min 32 chars
# [ ] FIELD_ENCRYPTION_KEY — generated, exactly 64 hex chars
# [ ] DATABASE_URL — not localhost
# [ ] REDIS_URL — port 6379 (not 379)
# [ ] ALLOWED_ORIGINS — explicit domains, no wildcard
# [ ] MT5_PASSWORD — not default/empty
# [ ] MT5_DEMO_MODE — false for live
# [ ] TELEGRAM_BOT_TOKEN — real token
# [ ] LICENSE_SECRET + LICENSE_SALT — both set
# [ ] ADMIN_IP_ALLOWLIST — your VPS IP
# [ ] DEBUG=false
# [ ] LOG_REDACTION_ENABLED=true
# [ ] SESSION_COOKIE_SECURE=true
# [ ] .env در .gitignore است
# [ ] .env.example در git است (بدون مقادیر واقعی)
