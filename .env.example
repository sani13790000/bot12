# =============================================================
# Galaxy Vast AI Trading Platform — Environment Configuration
# =============================================================
# Copy this file: cp .env.example .env
# Fill in ALL required fields before running docker compose up
# =============================================================

# ─────────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
PORT=8000
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# SUPABASE  [REQUIRED]
# Get from: https://supabase.com -> Settings -> API
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project-id.supabase.co:5432/postgres

# ─────────────────────────────────────────────────────────────
# SECURITY KEYS  [REQUIRED]
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Run this command 4 times to get 4 different keys.
# ─────────────────────────────────────────────────────────────
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
LICENSE_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_STRING
LICENSE_SIGNATURE_KEY=REPLACE_WITH_64_CHAR_HEX_STRING
LICENSE_SALT=galaxy-vast-salt-change-me

# ─────────────────────────────────────────────────────────────
# TELEGRAM  [OPTIONAL but recommended]
# 1. Message @BotFather on Telegram -> /newbot
# 2. Message @userinfobot -> get your numeric ID
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ADMIN_IDS=123456789,987654321

# ─────────────────────────────────────────────────────────────
# MetaTrader 5  [OPTIONAL - only for live trading]
# Requires Windows VPS with MT5 installed
# ─────────────────────────────────────────────────────────────
MT5_LOGIN=12345678
MT5_PASSWORD=your_broker_password
MT5_SERVER=YourBroker-Demo

# ─────────────────────────────────────────────────────────────
# TRADING PARAMETERS
# ─────────────────────────────────────────────────────────────
DEFAULT_SYMBOL=XAUUSD
DEFAULT_TIMEFRAME=M15
DEFAULT_RISK_PERCENT=1.0
MAX_DAILY_LOSS_PERCENT=3.0
MAX_OPEN_TRADES=3
MIN_CONFIDENCE_THRESHOLD=0.55
MIN_VOTE_SCORE=65.0

# ─────────────────────────────────────────────────────────────
# REDIS (Docker internal — change only if using external Redis)
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────────────────────
# MONITORING  [OPTIONAL]
# Sentry: https://sentry.io -> New Project -> Python -> DSN
# ─────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─────────────────────────────────────────────────────────────
# CORS (comma-separated list of allowed origins)
# ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8501"]

# ─────────────────────────────────────────────────────────────
# ML / AI SETTINGS
# ─────────────────────────────────────────────────────────────
ML_RETRAIN_INTERVAL_HOURS=24
BACKTEST_MAX_WORKERS=4
