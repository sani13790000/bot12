# .env.template -- Bot12 EA Platform v1.0.0
# Copy to .env.production or .env.staging and fill in real values.
# NEVER commit real .env files to version control.

# Application
ENVIRONMENT=production
APP_VERSION=1.0.0
GIT_SHA=

# Database
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Auth / JWT
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# HMAC Audit
HMAC_AUDIT_SECRET=

# Redis
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_PASSWORD=

# MT5
MT5_BROKER_SERVER=
MT5_LOGIN=
MT5_PASSWORD_HASH=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Webhook
WEBHOOK_HMAC_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=

# Monitoring
GRAFANA_PASSWORD=

# License
LICENSE_SALT=

# Secret Rotation
SECRET_ROTATION_ENABLED=true
SECRET_ROTATION_INTERVAL_DAYS=30
SECRET_GRACE_PERIOD_DAYS=7
