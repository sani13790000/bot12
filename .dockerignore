# .dockerignore — Phase 15 hardened
# Keeps Docker image lean + protects source code

# Git
.git
.gitignore

# Node
node_modules
npm-debug.log
frontend/node_modules
frontend/.next
frontend/dist

# Python
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info
dist
build
.eggs
.mypy_cache
.pytest_cache
.coverage
htmlcov

# Models (large files)
models/
*.pkl
*.joblib
*.h5
*.pt
*.pth

# Logs
logs/
*.log

# Env files
.env
.env.local
.env.*.local

# IDE
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose*.yml
Dockerfile*

# Docs
docs/
*.md
!README.md

# P15-FIX-4: MQL5 source MUST NOT go into Docker image
mql5/
*.mq5
*.mqh
*.ex5

# Release artifacts
releases/
source_archive/

# Scripts
scripts/
