# ── VCS ──────────────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── MQL5 source (P14-FIX-4 / P17-FIX-DI-1) — NEVER in Docker image ─────────
mql5/
*.mq5
*.mqh

# ── Release artifacts ─────────────────────────────────────────────────────────
releases/
scripts/

# ── Python artifacts ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Tests (not needed in runtime image) ──────────────────────────────────────
backend/tests/
**/test_*.py
**/*_test.py
conftest.py

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
*.env
*.secret
secrets/

# ── Frontend build artifacts (built separately) ───────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/dist/
node_modules/

# ── Dev tools ─────────────────────────────────────────────────────────────────
.venv/
venv/
env/
.tox/
.mypy_cache/
.ruff_cache/
.pytest_cache/
coverage.xml
.coverage
htmlcov/

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docs / CI config ─────────────────────────────────────────────────────────
docs/
*.md
.github/
.pre-commit-config.yaml

# ── Infra (not in app image) ──────────────────────────────────────────────────
infra/
docker-compose*.yml
Makefile
