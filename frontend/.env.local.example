# ========================================================================
# frontend/.env.local.example — Galaxy Vast Dashboard (React/Vite)
# ========================================================================
# Copy:  cp frontend/.env.local.example frontend/.env.local
# NEVER: هرگز .env.local را به git commit نکنید
# ========================================================================

# ----------------------------------------------------------------------
# Backend API URL (REQUIRED)
# ----------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
# Production:
# VITE_API_BASE_URL=https://api.yourdomain.com

# ----------------------------------------------------------------------
# WebSocket URL (REQUIRED)
# ----------------------------------------------------------------------
VITE_WS_URL=ws://localhost:8000
# Production:
# VITE_WS_URL=wss://api.yourdomain.com

# ----------------------------------------------------------------------
# Supabase (REQUIRED — برای auth در frontend)
# ----------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ----------------------------------------------------------------------
# App Config
# ----------------------------------------------------------------------
VITE_APP_NAME=Galaxy Vast
VITE_APP_VERSION=3.0.0
VITE_ENVIRONMENT=development

# ----------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_DEMO_MODE=false

# ----------------------------------------------------------------------
# Dashboard Refresh Intervals
# ----------------------------------------------------------------------
VITE_DASHBOARD_REFRESH_MS=5000
VITE_CHART_REFRESH_MS=1000

# ----------------------------------------------------------------------
# CHECKLIST
# ----------------------------------------------------------------------
# [ ] VITE_API_BASE_URL — به سرور backend اشاره می‌کند
# [ ] VITE_WS_URL — پروتکل ws:// (dev) یا wss:// (production)
# [ ] VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY — از Supabase Dashboard
# [ ] VITE_ENABLE_DEMO_MODE=false در production
